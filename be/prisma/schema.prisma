generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum Action {
  CREATE
  READ
  UPDATE
  DELETE
  MANAGE
  APPROVAL
}

enum Decision {
  ALLOW
  DENY
}

enum AttributeDataType {
  TEXT
  NUMBER
  DATE
  SELECT
  BOOLEAN
}

enum AssetStatus {
  AVAILABLE
  IN_USE
  UNDER_REPAIR
  DISPOSED
  LOST
}

enum AssetHistoryType {
  ASSIGN
  TRANSFER
  RETURN
  REPAIR
  DISPOSE
}

// ==================== MODELS ====================

model User {
  username  String    @id @db.Char(8)
  name      String?   @db.VarChar(100)
  email     String?   @unique @db.VarChar(254)
  password  String    @db.VarChar(255)
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  createdBy String    @map("created_by") @db.Char(8)
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(0)
  updatedBy String?   @map("updated_by") @db.Char(8)

  userRoles       UserRole[]
  userPermissions UserPermission[]

  @@map("users")
}

model Role {
  code      String    @id @db.VarChar(50)
  name      String    @db.VarChar(100)
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  createdBy String    @map("created_by") @db.Char(8)
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(0)
  updatedBy String?   @map("updated_by") @db.Char(8)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Feature {
  code      String    @id @db.VarChar(100)
  name      String    @db.VarChar(150)
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  createdBy String    @map("created_by") @db.Char(8)
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(0)
  updatedBy String?   @map("updated_by") @db.Char(8)

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("features")
}

/// Gán role cho user. Một user có thể có nhiều role.
/// section = null → role áp dụng toàn hệ thống.
/// section = "6100" → role chỉ có hiệu lực trong phạm vi section đó.
model UserRole {
  id       Int     @id @default(autoincrement())
  username String  @db.Char(8)
  roleCode String  @map("role_code") @db.VarChar(50)
  section  String? @db.Char(4)

  user User @relation(fields: [username], references: [username])
  role Role @relation(fields: [roleCode], references: [code])

  @@unique([username, roleCode, section])
  @@map("user_role")
}

/// Quyền của role trên feature.
/// Không có cột decision — có record = có quyền (additive-only).
/// section = null → quyền áp dụng cho tất cả section.
/// section = "6100" → quyền chỉ áp dụng cho section đó.
model RolePermission {
  id          Int     @id @default(autoincrement())
  roleCode    String  @map("role_code") @db.VarChar(50)
  featureCode String  @map("feature_code") @db.VarChar(100)
  action      Action
  section     String? @db.Char(4)

  role    Role    @relation(fields: [roleCode], references: [code])
  feature Feature @relation(fields: [featureCode], references: [code])

  @@unique([roleCode, featureCode, action, section])
  @@map("role_permission")
}

/// Override quyền cá nhân cho user.
/// decision = ALLOW → thêm quyền ngoài role.
/// decision = DENY  → rút quyền mà role đã cấp.
/// section = null → áp dụng toàn hệ thống.
/// section = "6100" → chỉ áp dụng trong section đó.
model UserPermission {
  id          Int      @id @default(autoincrement())
  username    String   @db.Char(8)
  featureCode String   @map("feature_code") @db.VarChar(100)
  action      Action
  decision    Decision
  section     String?  @db.Char(4)

  user    User    @relation(fields: [username], references: [username])
  feature Feature @relation(fields: [featureCode], references: [code])

  @@unique([username, featureCode, action, section])
  @@map("user_permission")
}

model Category {
  id                       String    @id @db.VarChar(30)
  name                     String    @db.VarChar(150)
  serialKey                String    @map("serial_key") @db.VarChar(30)
  maintenanceIntervalHours Int?      @map("maintenance_interval_hours")
  isActive                 Boolean   @default(true) @map("is_active")
  deletedAt                DateTime? @map("deleted_at") @db.Timestamptz(0)
  createdBy                String    @map("created_by") @db.Char(8)
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedBy                String?   @map("updated_by") @db.Char(8)
  updatedAt                DateTime? @map("updated_at") @db.Timestamptz(0)

  categoryAttributes CategoryAttribute[]
  models             ItemModel[]
  assets             Asset[]

  @@map("categories")
}

model AttributeGroup {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(150)
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(0)
  createdBy String    @map("created_by") @db.Char(8)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedBy String?   @map("updated_by") @db.Char(8)
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(0)

  attributes Attribute[]

  @@map("attribute_groups")
}

model Attribute {
  id              Int               @id @default(autoincrement())
  groupId         Int?              @map("group_id")
  name            String            @db.VarChar(150)
  measurementUnit String?           @map("measurement_unit") @db.VarChar(50)
  dataType        AttributeDataType @default(TEXT) @map("data_type")
  options         Json?             @db.Json
  isActive        Boolean           @default(true) @map("is_active")
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(0)
  createdBy       String            @map("created_by") @db.Char(8)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedBy       String?           @map("updated_by") @db.Char(8)
  updatedAt       DateTime?         @map("updated_at") @db.Timestamptz(0)

  group              AttributeGroup?        @relation(fields: [groupId], references: [id])
  categoryAttributes CategoryAttribute[]
  modelAttributeValues ModelAttributeValue[]
  assetAttributeValues AssetAttributeValue[]

  @@map("attributes")
}

model CategoryAttribute {
  categoryId  String  @map("category_id") @db.VarChar(30)
  attributeId Int     @map("attribute_id")
  sortOrder   Int     @default(0) @map("sort_order")
  isRequired  Boolean @default(false) @map("is_required")
  createdBy   String  @map("created_by") @db.Char(8)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedBy   String? @map("updated_by") @db.Char(8)
  updatedAt   DateTime? @map("updated_at") @db.Timestamptz(0)

  category  Category  @relation(fields: [categoryId], references: [id])
  attribute Attribute @relation(fields: [attributeId], references: [id])

  @@id([categoryId, attributeId])
  @@map("category_attributes")
}

model ItemModel {
  id               String    @id @db.VarChar(30)
  categoryId       String    @map("category_id") @db.VarChar(30)
  manufacturer     String?   @db.VarChar(150)
  name             String    @db.VarChar(150)
  manageType       String?   @map("manage_type") @db.VarChar(50)
  modelCode        String?   @map("model_code") @db.VarChar(50)
  isActive         Boolean   @default(true) @map("is_active")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(0)
  createdBy        String    @map("created_by") @db.Char(8)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedBy        String?   @map("updated_by") @db.Char(8)
  updatedAt        DateTime? @map("updated_at") @db.Timestamptz(0)

  category              Category               @relation(fields: [categoryId], references: [id])
  attributeValues       ModelAttributeValue[]
  assets                Asset[]

  @@map("models")
}

model ModelAttributeValue {
  attributeId Int     @map("attribute_id")
  modelId     String  @map("model_id") @db.VarChar(30)
  value       String? @db.Text

  attribute Attribute @relation(fields: [attributeId], references: [id])
  model     ItemModel @relation(fields: [modelId], references: [id])

  @@id([attributeId, modelId])
  @@map("model_attribute_values")
}


// ==================== DOCUMENT SEQUENCE ====================

enum ResetCycle {
  DAILY
  MONTHLY
  YEARLY
  NEVER
}

model DocumentSequence {
  id            Int        @id @default(autoincrement())
  code          String     @unique @db.VarChar(50)
  name          String     @db.VarChar(150)
  prefix        String     @default("") @db.VarChar(20)
  separator     String     @default("-") @db.VarChar(5)
  dateFormat    String     @default("YYYYMMDD") @map("date_format") @db.VarChar(20)
  paddingLength Int        @default(4) @map("padding_length")
  resetCycle    ResetCycle @default(DAILY) @map("reset_cycle")
  isActive      Boolean    @default(true) @map("is_active")
  deletedAt     DateTime?  @map("deleted_at") @db.Timestamptz(0)
  createdBy     String     @map("created_by") @db.Char(8)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedBy     String?    @map("updated_by") @db.Char(8)
  updatedAt     DateTime?  @map("updated_at") @db.Timestamptz(0)

  counters DocumentSequenceCounter[]

  @@map("document_sequences")
}

model DocumentSequenceCounter {
  id         Int      @id @default(autoincrement())
  sequenceId Int      @map("sequence_id")
  periodKey  String   @map("period_key") @db.VarChar(10)
  lastNumber Int      @default(0) @map("last_number")
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(0)

  sequence DocumentSequence @relation(fields: [sequenceId], references: [id])

  @@unique([sequenceId, periodKey])
  @@map("document_sequence_counters")
}

// ==================== ASSET ====================

model Asset {
  id                       String      @id @db.VarChar(50)
  assetCode                String?     @unique @map("asset_code") @db.VarChar(50)
  name                     String      @db.VarChar(200)
  categoryId               String      @map("category_id") @db.VarChar(30)
  modelId                  String?     @map("model_id") @db.VarChar(30)
  vendorId                 String?     @map("vendor_id") @db.VarChar(30)
  purchaseDate             DateTime?   @map("purchase_date") @db.Date
  purchasePrice            Decimal?    @map("purchase_price") @db.Decimal(15, 2)
  warrantyStartDate        DateTime?   @map("warranty_start_date") @db.Date
  warrantyEndDate          DateTime?   @map("warranty_end_date") @db.Date
  warrantyMonth            Int?        @map("warranty_month")
  serialNumber             String?     @map("serial_number") @db.VarChar(100)
  location                 String?     @db.VarChar(200)
  maintenanceIntervalHours Int?        @map("maintenance_interval_hours")
  lastMaintenanceDate      DateTime?   @map("last_maintenance_date") @db.Timestamptz(0)
  quantity                 Int         @default(1)
  remainQuantity           Int         @default(1) @map("remain_quantity")
  qrCode                   String?     @map("qr_code") @db.VarChar(255)
  assetStatus              AssetStatus @default(AVAILABLE) @map("asset_status")
  assignedTo               String?     @map("assigned_to") @db.Char(8)
  currentSection           String?     @map("current_section") @db.Char(4)
  deletedAt                DateTime?   @map("deleted_at") @db.Timestamptz(0)
  createdBy                String      @map("created_by") @db.Char(8)
  createdAt                DateTime    @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedBy                String?     @map("updated_by") @db.Char(8)
  updatedAt                DateTime?   @map("updated_at") @db.Timestamptz(0)

  category        Category              @relation(fields: [categoryId], references: [id])
  model           ItemModel?            @relation(fields: [modelId], references: [id])
  attributeValues AssetAttributeValue[]
  history         AssetHistory[]

  @@map("assets")
}

model AssetAttributeValue {
  id          Int     @id @default(autoincrement())
  attributeId Int     @map("attribute_id")
  assetId     String  @map("asset_id") @db.VarChar(50)
  value       String? @db.Text

  attribute Attribute @relation(fields: [attributeId], references: [id])
  asset     Asset     @relation(fields: [assetId], references: [id])

  @@unique([attributeId, assetId])
  @@map("asset_attribute_values")
}

model AssetHistory {
  id                Int              @id @default(autoincrement())
  assetId           String           @map("asset_id") @db.VarChar(50)
  type              AssetHistoryType
  location          String?          @db.VarChar(200)
  employeeId        String?          @map("employee_id") @db.VarChar(30)
  sectionId         String?          @map("section_id") @db.Char(4)
  employeeReceiveId String?          @map("employee_receive_id") @db.VarChar(30)
  sectionReceiveId  String?          @map("section_receive_id") @db.Char(4)
  quantity          Int?
  note              String?          @db.Text
  isActive          Boolean          @default(true) @map("is_active")
  createdBy         String           @map("created_by") @db.Char(8)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedBy         String?          @map("updated_by") @db.Char(8)
  updatedAt         DateTime?        @map("updated_at") @db.Timestamptz(0)

  asset Asset @relation(fields: [assetId], references: [id])

  @@map("asset_history")
}
