{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Vite Dev Server",
      "type": "shell",
      "command": "pnpm --filter itam-fe dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:.*https?://localhost"
        }
      }
    }
  ]
}
