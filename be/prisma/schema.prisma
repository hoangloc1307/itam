generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum Action {
  CREATE
  READ
  UPDATE
  DELETE
  MANAGE
  APPROVAL
}

enum Decision {
  ALLOW
  DENY
}

enum AttributeDataType {
  TEXT
  NUMBER
  DATE
  SELECT
  BOOLEAN
}

// ==================== MODELS ====================

model User {
  username  String    @id @db.Char(8)
  name      String?   @db.VarChar(100)
  email     String?   @unique @db.VarChar(254)
  password  String    @db.VarChar(255)
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  createdBy String    @map("created_by") @db.Char(8)
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(0)
  updatedBy String?   @map("updated_by") @db.Char(8)

  userRoles       UserRole[]
  userPermissions UserPermission[]

  @@map("users")
}

model Role {
  code      String    @id @db.VarChar(50)
  name      String    @db.VarChar(100)
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  createdBy String    @map("created_by") @db.Char(8)
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(0)
  updatedBy String?   @map("updated_by") @db.Char(8)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Feature {
  code      String    @id @db.VarChar(100)
  name      String    @db.VarChar(150)
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  createdBy String    @map("created_by") @db.Char(8)
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(0)
  updatedBy String?   @map("updated_by") @db.Char(8)

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("features")
}

/// Gán role cho user. Một user có thể có nhiều role.
/// section = null → role áp dụng toàn hệ thống.
/// section = "6100" → role chỉ có hiệu lực trong phạm vi section đó.
model UserRole {
  id       Int     @id @default(autoincrement())
  username String  @db.Char(8)
  roleCode String  @map("role_code") @db.VarChar(50)
  section  String? @db.Char(4)

  user User @relation(fields: [username], references: [username])
  role Role @relation(fields: [roleCode], references: [code])

  @@unique([username, roleCode, section])
  @@map("user_role")
}

/// Quyền của role trên feature.
/// Không có cột decision — có record = có quyền (additive-only).
/// section = null → quyền áp dụng cho tất cả section.
/// section = "6100" → quyền chỉ áp dụng cho section đó.
model RolePermission {
  id          Int     @id @default(autoincrement())
  roleCode    String  @map("role_code") @db.VarChar(50)
  featureCode String  @map("feature_code") @db.VarChar(100)
  action      Action
  section     String? @db.Char(4)

  role    Role    @relation(fields: [roleCode], references: [code])
  feature Feature @relation(fields: [featureCode], references: [code])

  @@unique([roleCode, featureCode, action, section])
  @@map("role_permission")
}

/// Override quyền cá nhân cho user.
/// decision = ALLOW → thêm quyền ngoài role.
/// decision = DENY  → rút quyền mà role đã cấp.
/// section = null → áp dụng toàn hệ thống.
/// section = "6100" → chỉ áp dụng trong section đó.
model UserPermission {
  id          Int      @id @default(autoincrement())
  username    String   @db.Char(8)
  featureCode String   @map("feature_code") @db.VarChar(100)
  action      Action
  decision    Decision
  section     String?  @db.Char(4)

  user    User    @relation(fields: [username], references: [username])
  feature Feature @relation(fields: [featureCode], references: [code])

  @@unique([username, featureCode, action, section])
  @@map("user_permission")
}

model Category {
  id                       String    @id @db.VarChar(30)
  name                     String    @db.VarChar(150)
  serialKey                String    @map("serial_key") @db.VarChar(30)
  maintenanceIntervalHours Int?      @map("maintenance_interval_hours")
  isActive                 Boolean   @default(true) @map("is_active")
  deletedAt                DateTime? @map("deleted_at") @db.Timestamptz(0)
  createdBy                String    @map("created_by") @db.Char(8)
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedBy                String?   @map("updated_by") @db.Char(8)
  updatedAt                DateTime? @map("updated_at") @db.Timestamptz(0)

  categoryAttributes CategoryAttribute[]
  models             ItemModel[]

  @@map("categories")
}

model AttributeGroup {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(150)
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(0)
  createdBy String    @map("created_by") @db.Char(8)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedBy String?   @map("updated_by") @db.Char(8)
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(0)

  attributes Attribute[]

  @@map("attribute_groups")
}

model Attribute {
  id              Int               @id @default(autoincrement())
  groupId         Int?              @map("group_id")
  name            String            @db.VarChar(150)
  measurementUnit String?           @map("measurement_unit") @db.VarChar(50)
  dataType        AttributeDataType @default(TEXT) @map("data_type")
  options         Json?             @db.Json
  isActive        Boolean           @default(true) @map("is_active")
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(0)
  createdBy       String            @map("created_by") @db.Char(8)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedBy       String?           @map("updated_by") @db.Char(8)
  updatedAt       DateTime?         @map("updated_at") @db.Timestamptz(0)

  group              AttributeGroup?     @relation(fields: [groupId], references: [id])
  categoryAttributes CategoryAttribute[]

  @@map("attributes")
}

model CategoryAttribute {
  categoryId  String  @map("category_id") @db.VarChar(30)
  attributeId Int     @map("attribute_id")
  sortOrder   Int     @default(0) @map("sort_order")
  isRequired  Boolean @default(false) @map("is_required")
  createdBy   String  @map("created_by") @db.Char(8)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedBy   String? @map("updated_by") @db.Char(8)
  updatedAt   DateTime? @map("updated_at") @db.Timestamptz(0)

  category  Category  @relation(fields: [categoryId], references: [id])
  attribute Attribute @relation(fields: [attributeId], references: [id])

  @@id([categoryId, attributeId])
  @@map("category_attributes")
}

model ItemModel {
  id               String    @id @db.VarChar(30)
  categoryId       String    @map("category_id") @db.VarChar(30)
  manufacturer     String?   @db.VarChar(150)
  name             String    @db.VarChar(150)
  manageType       String?   @map("manage_type") @db.VarChar(50)
  modelCode        String?   @map("model_code") @db.VarChar(50)
  isActive         Boolean   @default(true) @map("is_active")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(0)
  createdBy        String    @map("created_by") @db.Char(8)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedBy        String?   @map("updated_by") @db.Char(8)
  updatedAt        DateTime? @map("updated_at") @db.Timestamptz(0)

  category              Category               @relation(fields: [categoryId], references: [id])

  @@map("models")
}
